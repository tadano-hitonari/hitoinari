
@固有奥義_2845(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 奥義威力
#DIM 奥義実威力
#DIM 防御無視割合
#DIM 追加効果割合
#DIMS 奥義名

;==================================================
; 奥義切替:WILD5になると「オメガレックス・迫撃」が「兵器解放・荷電粒子砲」に変化する（使用時WILD5を消費）
;==================================================

IF 刻印現在数確認("WILD", 戦闘行動キャラ) >= 5

;--------------------
;荷電粒子砲
;--------------------

	IF 基礎BATTLE_STATE:キャラ番号:Lv >= 40
		奥義名 = 兵器解放・荷電粒子砲＋
		奥義威力 = 0
		奥義実威力 = 550
		防御無視割合 = 70
		追加効果割合 = 100
	ELSE
		奥義名 = 兵器解放・荷電粒子砲
		奥義威力 = 0
		奥義実威力 = 500
		防御無視割合 = 60
		追加効果割合 = 80
	ENDIF

	アビ汎用文字列:実行時メッセージ１ = 光の奔流が、立ちはだかるもの全てを破壊し尽くす！

	ELSE

;--------------------
;迫撃
;--------------------

	IF 基礎BATTLE_STATE:キャラ番号:Lv >= 40
		奥義名 = オメガレックス・迫撃＋
		奥義威力 = 550
		追加効果割合 = 100
	ELSE
		奥義名 = オメガレックス・迫撃
		奥義威力 = 500
		追加効果割合 = 80
	ENDIF

	アビ汎用文字列:実行時メッセージ１ = オメガレックスは爆発的加速で敵に詰め寄り、渾身の一撃を叩き込んだ！

	ENDIF

SELECTCASE ARGS
	CASE "奥義名"
		TSTR:コマンド名受渡 = %奥義名%

	CASE "奥義説明文"

		IF 刻印現在数確認("WILD", 戦闘行動キャラ) >= 5

			;==============================
			; 兵器解放・荷電粒子砲
			;==============================

			詳細文文字列受け渡し変数 = 奥義威力：{奥義実威力}％
			詳細文文字列受け渡し変数 += @"<br>防御力の{防御無視割合}％を無視し、敵全体に自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>恐怖効果（D枠・3ターン）を与える。成功率{追加効果割合}％。"
			詳細文文字列受け渡し変数 += @"<br>発動後、WILDを5消費する。"

		ELSE

			;==============================
			; オメガレックス・迫撃
			;==============================

			詳細文文字列受け渡し変数 = 奥義威力：{奥義威力}％
			詳細文文字列受け渡し変数 += @"<br>敵単体に自属性ダメージを与える。"
			詳細文文字列受け渡し変数 += @"<br>［1］のスロウ効果を与える。"
			詳細文文字列受け渡し変数 += @"<br>［1］（独自枠・3ターン）の最大ＣＴ増加効果を与える。成功率{追加効果割合}％。"
		IF ダンジョン表示モード == "戦闘画面"
			詳細文文字列受け渡し変数 += @"<br><font color='#%カラーパレット_HTML("緑")%'>◆WILDが5の時、[兵器解放・荷電粒子砲]に変化する。</font>"
		ELSE
			詳細文文字列受け渡し変数 += @"<br>◆WILDが5の時、[兵器解放・荷電粒子砲]に変化する。"
		ENDIF
	ENDIF

CASE "奥義追加効果"

	IF 刻印現在数確認("WILD", 戦闘行動キャラ) >= 5

		;荷電粒子砲
		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:ダメージ種類 = 奥義ダメージ
		CALL アビ対象選択テンプレート_敵全体_生者のみ
		アビ汎用変数:防御無視オプション_割合 = 防御無視割合
		アビ汎用変数:効果割合 = 奥義実威力
		CALL アビテンプレート_ダメージ処理_自属性

		;恐怖付与
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_敵全体_生者のみ
		アビ汎用文字列:バフ・デバフ枠 = 恐怖D
		アビ汎用文字列:バフ・デバフ対象能力 = 恐怖
		アビ汎用変数:持続ターン = 3
		アビ汎用変数:基礎成功確率 = 追加効果割合
		CALL アビテンプレート_不利効果_デバフ効果セット

		;WILD5消費
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ対象能力 = WILD
		CALL アビテンプレート_刻印減少(5)

	ELSE

		;オメガレックス・迫撃
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_指定(アビテンプレート用_奥義使用先保存:0)
		アビ汎用変数:効果量 = 1
		CALL アビテンプレート_不利効果_スロウ

		CALL アビ汎用変数文字列リセット
		アビ汎用文字列:バフ・デバフ枠 = OREX
		アビ汎用文字列:バフ・デバフ対象能力 = 最大ＣＴ増加
		アビ汎用変数:効果量 = 1
		アビ汎用変数:持続ターン = 3
		アビ汎用変数:基礎成功確率 = 追加効果割合
		CALL アビテンプレート_不利効果_デバフ効果セット

	ENDIF
ENDSELECT

RETURN 0