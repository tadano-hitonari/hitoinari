@固有アビ_2845_1(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 威力数値
#DIM 消費ＭＰ
#DIM 効果数値
#DIM 効果ターン
#DIMS アビ名

IF 基礎BATTLE_STATE:キャラ番号:Lv >= 30
	アビ名 = 対地対空両用速射砲＋＋
	威力数値 = 150
	消費ＭＰ = 50
	効果数値 = 70
	効果ターン = 5
ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 15
	アビ名 = 対地対空両用速射砲＋
	威力数値 = 125
	消費ＭＰ = 28
	効果数値 = 60
	効果ターン = 4
ELSEIF 基礎BATTLE_STATE:キャラ番号:Lv >= 1
	アビ名 = 対地対空両用速射砲
	威力数値 = 100
	消費ＭＰ = 19
	効果数値 = 50
	効果ターン = 3
ENDIF

SELECTCASE ARGS

CASE "アビ名"
	TSTR:コマンド名受渡 = %アビ名%

CASE "アビ説明文"

	IF 基礎BATTLE_STATE:キャラ番号:Lv >= 30
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
		詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力数値}％］の自属性ダメージを2回与える。"
		詳細文文字列受け渡し変数 += @"<br>自身に［{効果数値}％］（Ｄ枠・{効果ターン}ターン）の連続攻撃率上昇効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>味方全体に［20］の奥義ゲージUP効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>自身にWILDを1付与する。"
	ELSE
		詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
		詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力数値}％］の自属性ダメージを2回与える。"
		詳細文文字列受け渡し変数 += @"<br>自身に［{効果数値}％］（Ｄ枠・{効果ターン}ターン）の連続攻撃率上昇効果を与える。"
		詳細文文字列受け渡し変数 += @"<br>自身にWILDを1付与する。"
	ENDIF

CASE "アビ効果"

	IF 基礎BATTLE_STATE:キャラ番号:Lv >= 30

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_敵単体

		アビ汎用変数:効果割合 = 威力数値
		アビ汎用文字列:攻撃側使用能力値 = 攻撃力

		FOR LOCAL,0,2
			CALL アビテンプレート_ダメージ処理_自属性
		NEXT

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = 連続攻撃率D
		アビ汎用文字列:バフ・デバフ対象能力 = 連続攻撃率
		アビ汎用変数:効果量 = 効果数値
		アビ汎用変数:持続ターン = 効果ターン

		CALL アビテンプレート_有利効果_バフ効果セット

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_味方全体
		アビ汎用変数:効果量 = 20

		CALL アビテンプレート_有利効果_奥義ゲージUP

	ELSE

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_敵単体

		アビ汎用変数:効果割合 = 110
		アビ汎用文字列:攻撃側使用能力値 = 攻撃力

		FOR LOCAL,0,2
			CALL アビテンプレート_ダメージ処理_自属性
		NEXT
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ枠 = 連続攻撃率D
		アビ汎用文字列:バフ・デバフ対象能力 = 連続攻撃率
		アビ汎用変数:効果量 = 効果数値
		アビ汎用変数:持続ターン = 効果ターン

		CALL アビテンプレート_有利効果_バフ効果セット
		
	ENDIF
		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_自己のみ
		アビ汎用文字列:バフ・デバフ対象能力 = WILD
		アビ汎用変数:累積上限_固定値 = 5
		CALL アビテンプレート_刻印追加(1)
		
ENDSELECT

