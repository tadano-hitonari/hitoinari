@固有アビ_2845_4(ARGS, キャラ番号)
#DIM キャラ番号
#DIM 威力数値
#DIM 消費ＭＰ
#DIM バフ消去数
#DIMS アビ名

	IF 基礎BATTLE_STATE:キャラ番号:Lv >= 40
		威力数値 = 250
		消費ＭＰ = 20
		バフ消去数 = 1
	ELSE
		威力数値 = 150
		消費ＭＰ = 10
		バフ消去数 = 1
	ENDIF
	;バフ消去数を変えたくなった時のために
SELECTCASE ARGS

CASE "アビ名"
	TSTR:コマンド名受渡 = キラーバイティング

CASE "アビ説明文"
	詳細文文字列受け渡し変数 = 消費ＭＰ：{消費ＭＰ}
	詳細文文字列受け渡し変数 += @"<br>敵単体に［{威力数値}％］の自属性ダメージを与える。"
	詳細文文字列受け渡し変数 += @"<br>［{バフ消去数}］のバフ消去効果を与える。"

	IF ダンジョン表示モード == "戦闘画面"
		詳細文文字列受け渡し変数 += @"<br><font color='#%カラーパレット_HTML("赤")%'>◆被ダメージ時に自動発動</font>"
	ELSE
		詳細文文字列受け渡し変数 += @"<br>◆被ダメージ時に自動発動"
	ENDIF

	RETURN 消費ＭＰ

CASE "アビ効果"

	CALL アビ汎用変数文字列リセット
	CALL アビ対象選択テンプレート_敵単体

	アビ汎用変数:効果割合 = 威力数値

		CALL アビテンプレート_ダメージ処理_自属性

		CALL アビ汎用変数文字列リセット
		CALL アビ対象選択テンプレート_敵単体
		アビ汎用変数:基礎成功確率 = 100
		CALL アビテンプレート_不利効果_バフ消去

ENDSELECT

RETURN 消費ＭＰ